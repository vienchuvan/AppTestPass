<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VaultPass" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/onPrimary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="GlassCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/glass_surface</item>
        <item name="cardCornerRadius">28dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/glass_stroke</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="PremiumButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">20dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Legacy Style Aliases for Compatibility -->
    <style name="ModernButton" parent="PremiumButton" />
</resources>